<script>
  // ── TRIPTYQUE COUNTER ──
  const triBoxes = document.querySelectorAll('#tri1, #tri2, #tri3, #tri4');
  const triCounter = document.getElementById('triCounter');

  function updateCounter() {
    const checked = Array.from(triBoxes).filter(cb => cb.checked).length;
    triCounter.textContent = checked + ' / 4';
    triCounter.style.background = checked === 0 ? 'var(--sp-muted)' :
                                   checked === 4 ? 'linear-gradient(135deg,#5B2FC2,#3EC6F0)' :
                                   'var(--sp-violet)';
  }

  triBoxes.forEach(cb => cb.addEventListener('change', updateCounter));

  // ── TAG INPUT ──
  const tagWrapper = document.getElementById('tagWrapper');
  const tagInput   = document.getElementById('tagInput');

  tagInput.addEventListener('keydown', function(e) {
    if (e.key === 'Enter' || e.key === ',') {
      e.preventDefault();
      addTag(this.value.trim().replace(/,$/, ''));
    }
  });
  tagInput.addEventListener('blur', function() {
    if (this.value.trim()) addTag(this.value.trim());
  });
  tagWrapper.addEventListener('click', function() { tagInput.focus(); });

  function addTag(value) {
    if (!value) return;
    const tag = document.createElement('span');
    tag.className = 'tag';
    tag.innerHTML = value + '<span class="tag-remove" title="Supprimer">×</span>';
    tag.querySelector('.tag-remove').addEventListener('click', function() {
      tag.remove(); tagInput.focus();
    });
    tagWrapper.insertBefore(tag, tagInput);
    tagInput.value = '';
  }

  // ── WEBHOOK MAKE ──
  // ⚠️ REMPLACE CETTE URL PAR TON URL WEBHOOK MAKE
  const MAKE_WEBHOOK_URL = 'https://hook.eu1.make.com/n754uybhryh3ikx68kvpj3pptk9nt8us';

  function getChecked(selector) {
    return Array.from(document.querySelectorAll(selector + ' input:checked'))
      .map(cb => {
        const label = cb.closest('label') || cb.parentElement;
        return label ? label.textContent.replace('×','').trim() : '';
      }).filter(Boolean).join(', ');
  }

  function getRadio(name) {
    const el = document.querySelector('input[name="' + name + '"]:checked');
    if (!el) return '';
    const label = el.closest('label') || document.querySelector('label[for="' + el.id + '"]');
    return label ? label.textContent.trim() : '';
  }

  function getTags() {
    return Array.from(document.querySelectorAll('#tagWrapper .tag'))
      .map(t => t.textContent.replace('×','').trim()).join(', ');
  }

  function getAllTextareas() {
    const textareas = document.querySelectorAll('textarea');
    return Array.from(textareas).map((t, i) => t.value.trim());
  }

  function submitForm() {
    const btn = document.getElementById('submitBtn');
    const msg = document.getElementById('submitMsg');
    const inputs = document.querySelectorAll('input[type="text"], input[type="email"], input[type="url"]');
    const textareas = document.querySelectorAll('textarea');

    // Récupération des coordonnées (6 premiers inputs)
    const prenom   = inputs[0] ? inputs[0].value.trim() : '';
    const nom      = inputs[1] ? inputs[1].value.trim() : '';
