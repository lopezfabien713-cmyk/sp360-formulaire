    const linkedin = inputs[4] ? inputs[4].value.trim() : '';
    const siteweb  = inputs[5] ? inputs[5].value.trim() : '';

    // Validation minimale
    if (!prenom || !nom || !email) {
      msg.style.display = 'block';
      msg.style.color = '#cc0000';
      msg.textContent = '⚠️ Merci de remplir au minimum : Prénom, Nom et Email.';
      return;
    }

    const data = {
      // Identité
      prenom, nom, societe, email, linkedin, siteweb,

      // Section A
      q1_activite:          textareas[0] ? textareas[0].value.trim() : '',
      ca_min:               document.querySelectorAll('select')[0] ? document.querySelectorAll('select')[0].value : '',
      ca_max:               document.querySelectorAll('select')[1] ? document.querySelectorAll('select')[1].value : '',
      effectif_min:         document.querySelectorAll('select')[2] ? document.querySelectorAll('select')[2].value : '',
      effectif_max:         document.querySelectorAll('select')[3] ? document.querySelectorAll('select')[3].value : '',
      secteurs:             getChecked('.secteur-grid'),
      zones_geo:            getChecked('.secteur-grid:nth-of-type(2)'),
      q3_entreprises_cibles: textareas[1] ? textareas[1].value.trim() : '',

      // Section B
      fonctions_cibles:     getChecked('.fonction-grid'),
      niveau_hierarchique:  getRadio('niveau'),
      q4_cas_particuliers:  textareas[2] ? textareas[2].value.trim() : '',

      // Section C
      signaux_declencheurs: getChecked('.priority-group'),
      q5_autre_signal:      textareas[3] ? textareas[3].value.trim() : '',
      sources_veille:       getChecked('.source-freq-group'),

      // Section D
      ton_style:            getChecked('.checkbox-group'),
      registre_politesse:   getRadio('politesse'),
      niveau_naturel:       getRadio('naturel'),
      q8_structure_message: textareas[4] ? textareas[4].value.trim() : '',
      q8_formules_bannir:   textareas[5] ? textareas[5].value.trim() : '',

      // Section E
      q9_accroche_terrain:  textareas[6] ? textareas[6].value.trim() : '',
      vocabulaire_metier:   getTags(),
      livrables_souhaites:  getChecked('.triptyque-grid'),

      // Metadata
      date_soumission: new Date().toISOString(),
      source: 'SP360 Formulaire Calibrage V7'
    };

    // Envoi vers Make
    btn.disabled = true;
    btn.style.opacity = '0.6';
    btn.textContent = '⏳ Envoi en cours...';
    msg.style.display = 'none';

    fetch(MAKE_WEBHOOK_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data)
    })
    .then(res => {
      if (res.ok || res.status === 200) {
        btn.style.background = 'linear-gradient(135deg, #27a05b, #1d7a44)';
        btn.textContent = '✅ Calibrage envoyé avec succès !';
        msg.style.display = 'block';
        msg.style.color = '#27a05b';
        msg.textContent = 'Votre calibrage a bien été transmis à SP360. Notre équipe va traiter votre demande.';
      } else {
        throw new Error('Erreur serveur');
      }
    })
    .catch(err => {
      btn.disabled = false;
      btn.style.opacity = '1';
      btn.style.background = 'linear-gradient(135deg, #5B2FC2, #3EC6F0)';
      btn.textContent = '🚀 Envoyer mon calibrage à SP360';
      msg.style.display = 'block';
      msg.style.color = '#cc0000';
      msg.textContent = '❌ Erreur lors de l\'envoi. Vérifiez votre connexion et réessayez.';
    });
  }
</script>
</body>
</html>
